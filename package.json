{
  "name": "nadiyah-fights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nadiyah Fights is a Phaser + Colyseus multiplayer stick-figure fighting MVP.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "playtest": "playwright test"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.8",
    "@colyseus/sdk": "^0.17.26",
    "colyseus": "^0.17.8",
    "express": "^4.18.2",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.8"
  }
}
